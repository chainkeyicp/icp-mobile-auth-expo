# This project currently uses raw.icp0.io because the demo Motoko HTTP canister
# serves uncertified assets. Switch to icp0.io or a custom domain only after you
# add certified HTTP assets.
EXPO_PUBLIC_AUTH_FRONTEND_URL=https://<AUTH_CANISTER_ID>.raw.icp0.io
EXPO_PUBLIC_AUTH_APP_LINK_HOST=<AUTH_CANISTER_ID>.raw.icp0.io
EXPO_PUBLIC_AUTH_CALLBACK_URL=https://<AUTH_CANISTER_ID>.raw.icp0.io/auth-callback
EXPO_PUBLIC_IC_HOST=https://icp-api.io
EXPO_PUBLIC_SAMPLE_CANISTER_ID=
EXPO_PUBLIC_ICP_LEDGER_CANISTER_ID=ryjl3-tyaaa-aaaaa-aaaba-cai
EXPO_PUBLIC_MOBILE_AUTH_RETURN_MODE=code

# Used by `npm run build:auth-canister` to generate /.well-known/assetlinks.json.
# Replace with your release key or the Play App Signing SHA-256 before a store build.
ANDROID_PACKAGE_NAME=com.example.icpmobileauth
ANDROID_SHA256_CERT_FINGERPRINTS=FA:C6:17:45:DC:09:03:78:6F:B9:ED:E6:2A:96:2B:39:9F:73:48:F0:BB:6F:89:9B:83:32:66:75:91:03:3B:9C
